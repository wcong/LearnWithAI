/* 笔记查看器组件样式 */
.note-viewer {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #fff;
}

.note-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px;
  border-bottom: 1px solid var(--border-color);
  background: #fafafa;
  flex-shrink: 0;
}

.note-tool-left {
  display: flex;
  align-items: center;
}

.note-area-name {
  font-size: 15px;
  font-weight: 500;
  color: var(--text-primary);
}

.note-tool-right {
  display: flex;
  gap: 8px;
}

.tool-btn {
  font-size: 13px;
  padding: 4px 12px;
  border-radius: 6px;
  background: var(--card-bg);
  border: 1px solid var(--border-color);
  color: var(--text-regular);
  line-height: 1.8;
}

.tool-btn.active {
  background: rgba(102, 126, 234, 0.1);
  border-color: var(--primary-start);
  color: var(--primary-start);
}

.save-btn {
  background: var(--primary-gradient);
  color: #fff;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
  min-height: 0;
}

.save-btn::after {
  border: none;
  content: none;
}

.save-btn[disabled] {
  opacity: 0.5;
}

/* 查看模式 */
.note-view-mode {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
}

.note-content {
  line-height: 1.8;
  font-size: 15px;
  color: var(--text-primary);
}

.note-rich-text {
  word-break: break-word;
}

.note-rich-text img {
  max-width: 100%;
  height: auto;
}

.note-rich-text pre {
  background: #f5f5f5;
  padding: 12px;
  border-radius: 8px;
  overflow-x: auto;
  font-size: 13px;
}

.note-rich-text code {
  background: #f0f0f0;
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 13px;
}

.note-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200px;
}

.empty-text {
  color: var(--text-secondary);
  font-size: 14px;
}

/* 编辑模式 */
.note-edit-mode {
  flex: 1;
  padding: 12px;
}

.note-textarea {
  width: 100%;
  height: calc(100vh - 200px);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 12px;
  font-size: 15px;
  line-height: 1.6;
  color: var(--text-primary);
  background: #fafafa;
  box-sizing: border-box;
  resize: none;
}

.note-textarea:focus {
  border-color: var(--primary-start);
  background: #fff;
}
