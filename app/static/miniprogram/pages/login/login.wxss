/* 微信小程序一键登录页面样式 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #5b4fcf 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.login-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.12;
  background: #fff;
}

.bg-circle-1 {
  width: 300px;
  height: 300px;
  top: -80px;
  right: -60px;
}

.bg-circle-2 {
  width: 200px;
  height: 200px;
  bottom: -40px;
  left: -60px;
}

.bg-circle-3 {
  width: 150px;
  height: 150px;
  bottom: 30%;
  right: -30px;
}

.login-container {
  width: 100%;
  max-width: 380px;
  z-index: 1;
}

/* 品牌区 */
.brand-section {
  text-align: center;
  margin-bottom: 32px;
}

.brand-logo {
  width: 80px;
  height: 80px;
  margin: 0 auto 8px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.brand-logo-img {
  width: 80px;
  height: 80px;
  border-radius: 20px;
}

.brand-title {
  display: block;
  font-size: 28px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1px;
}

.brand-subtitle {
  display: block;
  font-size: 14px;
  color: rgba(255,255,255,0.8);
  margin-top: 6px;
}

/* 登录卡片 */
.login-card {
  background: #fff;
  border-radius: 20px;
  padding: 32px 24px;
  box-shadow: 0 8px 40px rgba(0,0,0,0.15);
}

/* 微信一键登录区域 */
.wechat-login-section {
  text-align: center;
  margin-bottom: 24px;
}

.wechat-login-title {
  display: block;
  font-size: 20px;
  font-weight: 700;
  color: #303133;
  margin-bottom: 8px;
}

.wechat-login-desc {
  display: block;
  font-size: 13px;
  color: #909399;
  line-height: 1.5;
}

/* 微信一键登录按钮 */
.wx-login-btn {
  width: 100%;
  height: 48px;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  font-size: 17px;
  font-weight: 600;
  border: none;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8px;
  box-shadow: 0 4px 16px rgba(7, 193, 96, 0.35);
  padding: 0;
}

.wx-login-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.wx-login-btn[disabled] {
  opacity: 0.7;
}

.wx-icon {
  width: 22px;
  height: 22px;
  margin-right: 8px;
}

/* 服务器配置 */
.server-config {
  text-align: center;
  margin-top: 16px;
}

.config-link {
  font-size: 13px;
  color: #909399;
  text-decoration: underline;
  padding: 4px;
}

/* 配置弹窗 */
.config-modal {
  background: #fff;
  border-radius: 16px;
  padding: 24px;
  width: 80%;
  max-width: 340px;
}

.config-title {
  display: block;
  font-size: 17px;
  font-weight: 600;
  margin-bottom: 12px;
  text-align: center;
}

.config-tip {
  display: block;
  font-size: 12px;
  color: #909399;
  margin-top: 6px;
  margin-bottom: 16px;
}

.config-btns {
  display: flex;
  gap: 12px;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 40px;
  border-radius: 10px;
  font-size: 15px;
  line-height: 40px;
  text-align: center;
}

.btn-cancel {
  background: #f0f0f0;
  color: #606266;
}

.btn-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s, visibility 0.3s;
}

.modal-mask.show {
  visibility: visible;
  opacity: 1;
}

/* 通用表单输入（配置弹窗用） */
.form-input {
  width: 100%;
  height: 44px;
  border: 2px solid #e8e8e8;
  border-radius: 12px;
  padding: 0 14px;
  font-size: 15px;
  color: #303133;
  background: #fafafa;
  box-sizing: border-box;
}
