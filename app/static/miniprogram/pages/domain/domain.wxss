/* 核心领域+AI对话页面样式 */
.domain-page {
  min-height: 100vh;
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
}

/* 顶部导航 - 固定常驻顶部 */
.domain-header {
  background: var(--primary-gradient);
  padding: 12px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  min-width: 0;
}

.header-right {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

.header-btn {
  color: #fff;
  font-size: 20px;
  padding: 6px;
  line-height: 1;
  cursor: pointer;
}

.header-title {
  color: #fff;
  font-size: 17px;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200px;
}

/* 抽屉操作按钮 */
.drawer-actions {
  padding: 8px 12px;
  border-bottom: 1px solid var(--border-color);
}

.action-btn {
  width: 100%;
  background: var(--primary-gradient);
  color: #fff;
  border: none;
  border-radius: var(--radius-sm);
  padding: 10px;
  font-size: 14px;
  font-weight: 500;
  text-align: center;
  display: block;
  box-sizing: border-box;
  line-height: 1.4;
  margin: 0;
  min-height: 0;
}

.action-btn::after {
  border: none;
  content: none;
}

/* 右侧抽屉 */
.drawer.right {
  left: auto;
  right: 0;
  width: 85%;
  max-width: 360px;
  transform: translateX(100%);
}

.drawer.right.show {
  transform: translateX(0);
}

/* 主内容区 */
.domain-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 消息列表 */
.message-list {
  flex: 1;
  overflow-y: auto;
  padding: 12px 16px 120px;
  -webkit-overflow-scrolling: touch;
}

.message-item {
  display: flex;
  margin-bottom: 16px;
  gap: 10px;
}

.message-item.user {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
  background: #f0f2f5;
}

.message-item.user .msg-avatar {
  background: rgba(102, 126, 234, 0.15);
}

.msg-bubble {
  max-width: 75%;
  padding: 10px 14px;
  border-radius: 16px;
  font-size: 15px;
  line-height: 1.6;
  word-break: break-word;
}

.message-item.user .msg-bubble {
  background: var(--primary-gradient);
  color: #fff;
  border-bottom-right-radius: 4px;
}

.message-item.assistant .msg-bubble {
  background: #fff;
  color: var(--text-primary);
  border-bottom-left-radius: 4px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}

.msg-content {
  white-space: pre-wrap;
}

.msg-time {
  font-size: 11px;
  color: var(--text-secondary);
  margin-top: 4px;
  text-align: right;
}

/* AI 消息操作按钮 */
.msg-actions {
  display: flex;
  gap: 6px;
  margin-top: 8px;
  flex-wrap: wrap;
}

.msg-action-btn {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 12px;
  border: 1px solid var(--border-color);
  background: transparent;
  cursor: pointer;
  line-height: 1.4;
  min-height: 0;
}

.msg-action-btn::after {
  border: none;
}

.msg-action-btn.sub-btn {
  color: var(--primary-start);
  border-color: var(--primary-start);
  background: rgba(102, 126, 234, 0.06);
}

.msg-action-btn.sub-btn:active {
  background: var(--primary-start);
  color: #fff;
}

.msg-action-btn.gen-btn {
  color: #6366f1;
  border-color: #6366f1;
  background: transparent;
}

.msg-action-btn.gen-btn:active {
  background: #6366f1;
  color: #fff;
}

.message-item.user .msg-time {
  color: rgba(255,255,255,0.7);
}

/* 加载更多 */
.loading-more {
  padding: 12px;
  text-align: center;
}

/* 空状态 */
.empty-chat {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 15px;
  color: var(--text-secondary);
  margin-bottom: 4px;
}

.empty-hint {
  font-size: 13px;
  color: var(--info-color);
}

/* 输入区 - 固定在底部导航上方 */
.input-area {
  position: fixed;
  bottom: calc(24px + var(--safe-bottom, 0px));
  left: 0;
  right: 0;
  z-index: 50;
  background: #fff;
  border-top: 1px solid var(--border-color);
  padding: 6px 12px;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
}

.skill-selector {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  border-radius: 12px;
  background: #f0f2f5;
  margin-bottom: 6px;
  font-size: 12px;
  color: var(--text-secondary);
  cursor: pointer;
}

.skill-tag {
  max-width: 80px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.skill-arrow {
  font-size: 10px;
}

.input-row {
  display: flex;
  align-items: flex-end;
  gap: 8px;
}

.chat-input {
  flex: 1;
  border: 1px solid var(--border-color);
  border-radius: 20px;
  padding: 8px 14px;
  font-size: 15px;
  line-height: 1.4;
  color: var(--text-primary);
  background: #f9fafb;
  max-height: 100px;
  min-height: 36px;
  box-sizing: border-box;
  resize: none;
}

.chat-input:focus {
  border-color: var(--primary-start);
  background: #fff;
}

.send-btn {
  width: 56px;
  height: 40px;
  background: var(--primary-gradient);
  color: #fff;
  border: none;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  cursor: pointer;
  padding: 0;
  margin: 0;
  line-height: 1;
  min-height: 0;
}

.send-btn::after {
  border: none;
  content: none;
}

.send-btn[disabled] {
  opacity: 0.5;
}

.send-btn.sending {
  opacity: 0.7;
}

/* 模态弹窗扩展 */
.modal-content.full {
  max-height: 70vh;
  width: 90%;
}

/* 操作菜单 */
.action-menu {
  background: #fff;
  border-radius: 16px;
  width: 80%;
  max-width: 300px;
  overflow: hidden;
}

.action-item {
  padding: 14px 20px;
  font-size: 15px;
  color: var(--text-primary);
  border-bottom: 1px solid #f0f0f0;
  text-align: center;
  cursor: pointer;
}

.action-item:active {
  background: #f5f5f5;
}

.action-item.danger {
  color: var(--danger-color);
}

.action-item.cancel-action {
  color: var(--text-secondary);
  font-weight: 500;
  border-bottom: none;
}

/* 表单 */
.form-item {
  margin-bottom: 14px;
}

.form-label {
  font-size: 14px;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 6px;
}

.form-input {
  width: 100%;
  height: 40px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  padding: 0 12px;
  font-size: 14px;
  color: var(--text-primary);
  background: #fafafa;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 80px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  padding: 10px 12px;
  font-size: 14px;
  color: var(--text-primary);
  background: #fafafa;
  box-sizing: border-box;
  resize: none;
}

.form-hint {
  display: block;
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 12px;
}

.modal-btns {
  display: flex;
  gap: 10px;
  margin-top: 16px;
}

.modal-btn {
  flex: 1;
  height: 40px;
  line-height: 40px;
  border-radius: var(--radius-sm);
  font-size: 14px;
  font-weight: 500;
  text-align: center;
  cursor: pointer;
  padding: 0;
  margin: 0;
  display: block;
  box-sizing: border-box;
  min-height: 0;
}

.modal-btn::after {
  border: none;
  content: none;
}

.modal-btn.confirm {
  background: var(--primary-gradient);
  color: #fff;
}

.modal-btn.cancel {
  background: #f0f0f0;
  color: var(--text-regular);
}

/* 搜索结果 */
.search-results {
  margin-top: 12px;
  max-height: 300px;
  overflow-y: auto;
}

.search-item {
  padding: 10px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  margin-bottom: 8px;
}

.search-item-content {
  display: block;
  font-size: 13px;
  color: var(--text-primary);
  margin-bottom: 4px;
  line-height: 1.5;
}

.search-item-score {
  display: block;
  font-size: 11px;
  color: var(--text-secondary);
}

/* 审查面板 */
.examine-content, .generate-content {
  max-height: 50vh;
  padding: 12px 0;
}

/* 生成的子领域项 */
.subarea-item {
  margin-bottom: 10px;
  padding: 8px;
  border: 1px solid #eee;
  border-radius: 8px;
}

.subarea-item .form-input {
  margin-bottom: 6px;
}

.subarea-item .subarea-desc {
  font-size: 13px;
}

/* 技能选择 */
.skill-list {
  max-height: 300px;
}

.skill-item {
  padding: 12px 16px;
  border-bottom: 1px solid #f0f0f0;
  cursor: pointer;
}

.skill-item:active {
  background: #f5f5f5;
}

.skill-item.active {
  background: rgba(102, 126, 234, 0.08);
  border-left: 3px solid var(--primary-start);
}

.skill-name {
  display: block;
  font-size: 15px;
  color: var(--text-primary);
  font-weight: 500;
}

.skill-desc {
  display: block;
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 2px;
}
