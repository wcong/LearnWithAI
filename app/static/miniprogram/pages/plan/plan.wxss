/* Plan Mode 页面样式 - 暗色主题 */
.plan-page {
  min-height: 100vh;
  background: #1a1a2e;
  padding-bottom: 36px;
  color: #e0e0e0;
}

/* 顶部导航 */
.plan-header {
  background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
  padding: 12px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.back-btn {
  font-size: 22px;
  margin-right: 8px;
}

.header-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border-radius: 20px;
  background: rgba(255,255,255,0.1);
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.status-dot.exploring {
  background: #4facfe;
  animation: pulse-dot 1.5s infinite;
}

.status-dot.done {
  background: #67c23a;
}

.status-dot.error {
  background: #f56c6c;
}

.status-dot.stopped {
  background: #e6a23c;
}

.status-text {
  font-size: 12px;
  color: rgba(255,255,255,0.8);
}

/* 探索中状态 */
.plan-exploring {
  padding: 16px;
}

/* 状态栏 */
.status-bar-custom {
  display: flex;
  justify-content: space-around;
  background: rgba(255,255,255,0.05);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.status-item {
  text-align: center;
}

.status-label {
  display: block;
  font-size: 11px;
  color: rgba(255,255,255,0.5);
  margin-bottom: 4px;
}

.status-value {
  display: block;
  font-size: 20px;
  font-weight: 700;
  color: #4facfe;
}

/* 进度条 */
.progress-bar {
  height: 6px;
  background: rgba(255,255,255,0.1);
  border-radius: 3px;
  margin-bottom: 16px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4facfe, #00f2fe);
  border-radius: 3px;
  transition: width 0.5s ease;
}

/* 领域树预览 */
.plan-tree-section {
  margin-bottom: 16px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
  margin-bottom: 8px;
  padding-left: 4px;
}

.plan-tree {
  max-height: 200px;
  background: rgba(255,255,255,0.04);
  border-radius: 12px;
  padding: 8px 0;
}

/* 消息流 */
.plan-messages {
  margin-bottom: 16px;
}

.messages-scroll {
  max-height: 300px;
  background: rgba(255,255,255,0.04);
  border-radius: 12px;
  padding: 12px;
}

.plan-msg-item {
  margin-bottom: 12px;
  padding: 10px;
  border-radius: 8px;
  background: rgba(255,255,255,0.05);
}

.plan-msg-item.message {
  border-left: 3px solid #4facfe;
}

.plan-msg-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6px;
}

.plan-msg-area {
  font-size: 12px;
  font-weight: 500;
  color: #4facfe;
}

.plan-msg-time {
  font-size: 11px;
  color: rgba(255,255,255,0.4);
}

.plan-msg-content {
  font-size: 13px;
  line-height: 1.5;
  color: #d0d0d0;
  word-break: break-word;
}

/* 进度框 */
.progress-box {
  background: rgba(79, 172, 254, 0.1);
  border: 1px solid rgba(79, 172, 254, 0.2);
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 16px;
}

.progress-text {
  font-size: 13px;
  color: #4facfe;
  line-height: 1.5;
}

/* 操作按钮 */
.plan-actions {
  text-align: center;
  margin-bottom: 20px;
}

.stop-btn {
  background: rgba(245, 108, 108, 0.2);
  border: 1px solid rgba(245, 108, 108, 0.4);
  color: #f56c6c;
  font-size: 14px;
  font-weight: 500;
  padding: 10px 32px;
  border-radius: 20px;
}

/* 未开始状态 */
.plan-start {
  padding: 20px 16px;
}

/* 品牌简介 */
.plan-intro {
  text-align: center;
  padding: 30px 0;
}

.intro-icon {
  font-size: 56px;
  display: block;
  margin-bottom: 12px;
}

.intro-title {
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: #4facfe;
  margin-bottom: 8px;
}

.intro-desc {
  display: block;
  font-size: 14px;
  color: rgba(255,255,255,0.5);
  line-height: 1.6;
  max-width: 300px;
  margin: 0 auto;
}

/* 输入区 */
.plan-input-section {
  background: rgba(255,255,255,0.05);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: rgba(255,255,255,0.7);
  margin-bottom: 8px;
}

.plan-textarea {
  width: 100%;
  min-height: 80px;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  padding: 12px;
  font-size: 15px;
  line-height: 1.5;
  color: #e0e0e0;
  background: rgba(0,0,0,0.3);
  box-sizing: border-box;
  resize: none;
}

.plan-textarea:focus {
  border-color: #4facfe;
}

/* 快捷提示 */
.prompt-suggestions {
  margin-bottom: 16px;
}

.suggestion-title {
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  margin-bottom: 8px;
  display: block;
}

.suggestion-scroll {
  display: flex;
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 4px;
}

.suggestion-chip {
  display: inline-flex;
  padding: 6px 14px;
  margin-right: 8px;
  border-radius: 16px;
  background: rgba(79, 172, 254, 0.15);
  border: 1px solid rgba(79, 172, 254, 0.25);
  font-size: 13px;
  color: #4facfe;
  flex-shrink: 0;
  cursor: pointer;
}

.suggestion-chip:active {
  background: rgba(79, 172, 254, 0.25);
}

/* 深度选择 */
.depth-selector {
  margin-bottom: 20px;
}

.depth-options {
  display: flex;
  gap: 10px;
}

.depth-chip {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 600;
  color: rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.08);
  cursor: pointer;
  transition: all 0.2s;
}

.depth-chip.active {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff;
  box-shadow: 0 4px 12px rgba(79, 172, 254, 0.3);
}

/* 开始按钮 */
.start-btn {
  width: 100%;
  height: 48px;
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: #fff;
  font-size: 17px;
  font-weight: 600;
  border: none;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 20px rgba(79, 172, 254, 0.3);
}

.start-btn[disabled] {
  opacity: 0.4;
}

/* 结果统计 */
.plan-results {
  background: rgba(255,255,255,0.05);
  border-radius: 16px;
  padding: 20px;
  margin-top: 16px;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  margin-top: 12px;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: #4facfe;
  margin-bottom: 4px;
}

.stat-label {
  display: block;
  font-size: 12px;
  color: rgba(255,255,255,0.5);
}

/* 底部导航覆盖 */
.plan-bottom-nav {
  background: #16213e !important;
  border-top-color: rgba(255,255,255,0.1) !important;
}

.plan-bottom-nav .nav-item {
  color: rgba(255,255,255,0.4) !important;
}

.plan-bottom-nav .nav-item.active {
  color: #4facfe !important;
}

/* 空状态暗色适配 */
.plan-page .empty-state {
  color: rgba(255,255,255,0.3);
}
